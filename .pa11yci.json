{
  "runners": ["axe"],
  "timeout": 10000,
  "wait": 1000,
  "chromeLaunchConfig": {
    "args": ["--no-sandbox", "--disable-setuid-sandbox"]
  },
  "standard": "WCAG2AA",
  "threshold": 10,
  "urls": [
    "http://localhost:3000/auth/login",
    "http://localhost:3000/dashboard"
  ],
  "headers": {
    "Accept-Language": "en-US"
  }
}
