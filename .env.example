# ============================================================
# AgentFlow-AI — Environment Variables Template
# ============================================================
# NEVER commit real secrets to git.
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
# ============================================================

# --- Supabase (Database & Auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Alias used by production gate checks:
SUPABASE_URL=

# --- OpenAI (AI Text, Image, Video Generation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TEXT_MODEL=
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_SIZE=1792x1024
OPENAI_IMAGE_QUALITY=hd
OPENAI_VIDEO_MODEL=
OPENAI_VIDEO_SIZE=1920x1080

# --- Token Encryption (used for ad provider token storage + SSO client secrets) ---
AD_TOKEN_ENCRYPTION_KEY=
NEXTAUTH_SECRET=

# --- SSO / Enterprise Identity (Google Workspace, Microsoft Entra) ---
# Google Workspace SSO (OIDC via Supabase Auth)
# GOOGLE_WORKSPACE_SSO_CLIENT_ID=
# GOOGLE_WORKSPACE_SSO_CLIENT_SECRET=
# GOOGLE_WORKSPACE_SSO_DOMAIN=your-company.com
# Microsoft Entra ID SSO (OIDC via Supabase Auth)
# MICROSOFT_ENTRA_SSO_CLIENT_ID=
# MICROSOFT_ENTRA_SSO_CLIENT_SECRET=
# MICROSOFT_ENTRA_SSO_TENANT_ID=
# MICROSOFT_ENTRA_SSO_DOMAIN=your-company.com
# Shared SSO settings
SSO_REQUIRE_DOMAIN_MATCH=true
SSO_ALLOW_SIGNUP=false
# Base URL used in SSO redirect callbacks
NEXTAUTH_URL=

# --- n8n (Workflow Automation Engine) ---
N8N_WEBHOOK_URL=
N8N_CALLBACK_SECRET=
N8N_WEBHOOK_HOST_ALLOWLIST=
N8N_TASK_WEBHOOK=
N8N_BASE_URL=
N8N_URL=
# Enable/disable task execution via n8n (default: true)
TASK_EXECUTION_ENABLED=true

# --- App Deployment ---
APP_BASE_URL=
NEXT_PUBLIC_APP_URL=
NEXTAUTH_URL=
# Set by Vercel automatically (used for dynamic origin detection):
# VERCEL_URL

# --- Cron / Ops ---
CRON_SECRET=

# --- Redis / Rate Limiting ---
RATE_LIMIT_STORE=upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Direct Redis connection (used by BullMQ queues):
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Sentry (Error Tracking & Source Maps) ---
# withSentryConfig (next.config.ts) uploads source maps during `next build`
# when these are present. Set SENTRY_UPLOAD_SOURCEMAPS=false to disable.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_UPLOAD_SOURCEMAPS=true
SENTRY_DEBUG=false
# Set by Vercel automatically; override for local/release naming:
# SENTRY_RELEASE
# VERCEL_GIT_COMMIT_SHA

# --- External Alerts (Email via Resend + Slack Webhook) ---
# All alerts are disabled-by-config until you enable a channel.
# Master on/off for external alert dispatch (default: true).
# ALERTS_ENABLED=true
# Email channel (Resend)
EMAIL_ALERTS_ENABLED=true
EMAIL_ALERTS_FROM=onboarding@resend.dev
EMAIL_ALERTS_TO=
RESEND_API_KEY=
# Slack channel (webhook)
SLACK_WEBHOOK_ENABLED=true
SLACK_WEBHOOK_URL=
# High-error-rate alert threshold, as a fraction (default: 0.05 = 5%)
ALERT_ERROR_RATE_THRESHOLD=0.05
# Alerting thresholds (W20-T2)
ALERT_LATENCY_P95_MS=1500
ALERT_REDIS_MEMORY_WARN_MB=0
ALERT_DB_LAG_WARN_SECONDS=0
ALERT_BACKUP_MAX_AGE_DAYS=1
# Optional channel allow-list, e.g. "slack,email,webhook" (empty = all enabled)
ALERT_CHANNELS=
# Generic webhook / PagerDuty incident channel
WEBHOOK_ALERTS_ENABLED=false
WEBHOOK_ALERTS_URL=
PAGERDUTY_ROUTING_KEY=
# Quota alert thresholds are constants in src/lib/usage/quota-alerts.ts

# --- Meta (Facebook/Instagram) Ads ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_GRAPH_API_VERSION=v22.0

# --- Pinterest Ads ---
PINTEREST_APP_ID=
PINTEREST_CLIENT_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=
PINTEREST_API_VERSION=v5

# --- Google Ads ---
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v19

# --- Security / Auth ---
# Comma-separated emails exempt from brute-force protection
SPECIAL_AUTH_EMAILS=
# GitHub personal access token (for PR/release automation)
GITHUB_TOKEN=

# --- Features ---
# Enable/disable Alex AI assistant chat (/api/alex/chat)
ALEX_ASSISTANT_ENABLED=true

# --- PDF / Browser (Server-side PDF generation) ---
PUPPETEER_EXECUTABLE_PATH=
CHROME_PATH=

# --- Network / Safety ---
# Total retry timeout for safeFetch (ms). Default: 10000
# SAFE_FETCH_TOTAL_RETRY_TIMEOUT_MS=10000
# Max payload bytes for task execution. Default: 262144
# PAYLOAD_MAX_BYTES=262144

# --- Production Gate / Deploy Markers ---
# Set by CI after successful audit
# PRODUCTION_AUDIT_PASSED=true
# OPERATIONAL_LOG_VISIBILITY_CONFIRMED=true
