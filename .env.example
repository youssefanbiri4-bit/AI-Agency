# ============================================================
# AgentFlow-AI — Environment Variables Template
# ============================================================
# NEVER commit real secrets to git.
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Token Encryption ---
AD_TOKEN_ENCRYPTION_KEY=your-long-random-encryption-key-here

# --- n8n ---
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/...
N8N_CALLBACK_SECRET=your-long-random-callback-secret
N8N_WEBHOOK_HOST_ALLOWLIST=your-n8n-host.com

# --- Stripe (scaffold only) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ALLOW_LIVE_MODE=false

# --- Cron / Ops ---
CRON_SECRET=your-cron-secret-here

# --- Optional / Other ---
# SENTRY_DSN=...
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
