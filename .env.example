# ============================================================
# AgentFlow-AI — Environment Variables Template
# ============================================================
# NEVER commit real secrets to git.
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5.5

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Token Encryption
AD_TOKEN_ENCRYPTION_KEY=your-encryption-key-here

# n8n
N8N_WEBHOOK_URL=https://hamidnbiri.app.n8n.cloud/webhook/
N8N_CALLBACK_SECRET=your-long-random-callback-secret
N8N_WEBHOOK_HOST_ALLOWLIST=hamidnbiri.app.n8n.cloud

# Stripe (scaffold only)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_ALLOW_LIVE_MODE=false

# Cron / Ops
CRON_SECRET=your-cron-secret-here

# Optional / Other
# SENTRY_DSN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Production Gate Markers (set by CI before deploy)
 PRODUCTION_AUDIT_PASSED=true
 PRODUCTION_AUDIT_DATE=2026-07-05T00:00:00Z
 PRODUCTION_AUDIT_COMMIT_SHA=your-commit-sha-here
 OPERATIONAL_LOG_VISIBILITY_CONFIRMED=true